---
import Base from '../layouts/Base.astro';
import storefront from '../assets/photos/storefront.jpg';
import counterSale from '../assets/photos/counter-sale.jpg';
import supermarket from '../assets/photos/supermarket.jpg';
import stockCheck from '../assets/photos/stock-check.jpg';
import creditBook from '../assets/photos/credit-book.jpg';
import customerApp from '../assets/photos/customer-app.jpg';
import diasporaFamily from '../assets/photos/diaspora-family.jpg';
// CMS-managed content (admin edits these JSON files via Decap /admin)
import pricing from '../content/data/pricing.json';
import contact from '../content/data/contact.json';
import faq from '../content/data/faq.json';
const telHref = (p) => 'tel:' + p.replace(/\s/g, '');

// Hero hub-and-spoke — the HONEST live ZAYA network. Six nodes only (fewer,
// truer): the three participants + the three live/launching capabilities. No
// unbuilt verticals here. Delivery + the diaspora basket are vision, so they are
// NOT shown as live equals (offered separately as clearly-dimmed "coming" nodes
// only on request). Positions are computed on an even ring so the canvas spokes
// (drawn client-side) always meet the SSR-rendered cards. Icons are ZAYA's own
// line set — never the reference graphic's icons or its non-brand palette.
const HUB = [
  { key: 'customers', label: 'Customers',      tone: 'teal',  a: -90,
    d: 'M9 11a3 3 0 100-6 3 3 0 000 6zM3.5 20a5.5 5.5 0 0111 0M16 5.4a3 3 0 010 5.2M20.5 20a5.5 5.5 0 00-3-4.9' },
  { key: 'nearby',    label: 'Browse nearby',  tone: 'navy',  a: -30,
    d: 'M12 21s-6-5.2-6-10a6 6 0 0112 0c0 4.8-6 10-6 10zM12 13a2.2 2.2 0 100-4.4 2.2 2.2 0 000 4.4z' },
  { key: 'compare',   label: 'Compare prices', tone: 'coral', a: 30,
    d: 'M12 4v16M7 20h10M7 8h10M7 8l-3 5.2a3 3 0 006 0zM17 8l-3 5.2a3 3 0 006 0z' },
  { key: 'merchants', label: 'Merchants',      tone: 'teal',  a: 90,
    d: 'M6.2 8h11.6l-1 12H7.2l-1-12zM9 8V6.2a3 3 0 016 0V8' },
  { key: 'credit',    label: 'Credit book',    tone: 'navy',  a: 150,
    d: 'M12 6.4C10.4 5.4 7.8 5 5 5.6V19c2.8-.6 5.4-.2 7 .9 1.6-1.1 4.2-1.5 7-.9V5.6c-2.8-.6-5.4-.2-7 .8zM12 6.4V19.9' },
  { key: 'shops',     label: 'Shops',          tone: 'coral', a: 210,
    d: 'M4.5 9l1-4.2A1 1 0 016.5 4h11a1 1 0 011 .8L20 9M5.4 9v9.5a1 1 0 001 1h11.2a1 1 0 001-1V9M4.5 9h15' }
].map((n) => {
  const rad = (n.a * Math.PI) / 180, R = 35;
  return { ...n, xp: +(50 + R * Math.cos(rad)).toFixed(2), yp: +(50 + R * Math.sin(rad)).toFixed(2) };
});
---
<Base>
<header class="site-header">
  <div class="pilot-strip">
    <div class="wrap pilot-strip-in">
      <span><i aria-hidden="true"></i><b>Merchant pilot live</b> in Addis Ababa</span>
      <a href="#contact">Request pilot access <span aria-hidden="true">&rarr;</span></a>
    </div>
  </div>
  <div class="wrap nav">
    <a class="lock" href="#top" aria-label="ZAYA App — Everything near you">
      <svg class="mk" viewBox="0 0 512 512" role="img" aria-hidden="true">
        <defs>
          <linearGradient id="zg" x1="0" y1="0" x2="1" y2="1"><stop offset="0" stop-color="#13B7B4"/><stop offset="1" stop-color="#0B8B8A"/></linearGradient>
          <clipPath id="zc"><rect width="512" height="512" rx="115"/></clipPath>
        </defs>
        <g clip-path="url(#zc)"><rect width="512" height="512" fill="url(#zg)"/>
          <circle class="rr" cx="256" cy="200" r="288"/><circle class="rr rr2" cx="256" cy="200" r="288"/><circle class="rr rr3" cx="256" cy="200" r="288"/></g>
        <path d="M333.7 249.2 L256 372 L178.3 249.2 A92 92 0 1 1 333.7 249.2 Z" fill="#fff"/>
        <circle cx="256" cy="200" r="56" fill="#FF7A45"/>
        <polyline points="224,180 286,180 226,220 289,220" fill="none" stroke="#fff" stroke-width="17" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <span class="txt">
        <span class="wm">ZAYA <b>App</b></span>
        <span class="tl">Everything near you.</span>
      </span>
    </a>
    <nav class="menu" id="primary-menu" aria-label="Primary">
      <div class="item"><a href="#top">Home</a></div>
      <div class="item">
        <a href="#solutions" aria-haspopup="true" aria-expanded="false">Features <svg class="ch" viewBox="0 0 24 24" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg></a>
        <div class="drop" aria-label="ZAYA features">
          <a href="#solutions">Sales &amp; inventory <span class="st live">Live</span></a>
          <a href="#solutions">The credit book <span class="st live">Live</span></a>
          <a href="#solutions">Find &amp; compare shops <span class="st launch">Launching</span></a>
          <a href="#solutions">Local delivery <span class="st road">Roadmap</span></a>
          <a href="#diaspora">The diaspora basket <span class="st road">Our vision</span></a>
        </div>
      </div>
      <div class="item">
        <a href="#experience" aria-haspopup="true" aria-expanded="false">For you <svg class="ch" viewBox="0 0 24 24" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg></a>
        <div class="drop" aria-label="Choose your role">
          <a href="#experience" data-role-jump="merchant">Merchants <span class="st live">Live</span></a>
          <a href="#experience" data-role-jump="customer">Customers <span class="st launch">Launching</span></a>
          <a href="#experience" data-role-jump="diaspora">Diaspora <span class="st road">Our vision</span></a>
        </div>
      </div>
      <div class="item"><a href="#pricing">Pricing</a></div>
      <div class="item"><a href="#faq">FAQ</a></div>
      <button class="menu-ai" type="button" data-open-assistant>Ask ZAYA AI</button>
    </nav>
    <a class="btn btn-primary cta" href="#contact">Join the pilot</a>
    <button class="burger" type="button" aria-label="Menu" aria-expanded="false" aria-controls="primary-menu">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<div class="hero" id="top">
  <div class="wrap hero-in">
    <div class="copy">
      <span class="eyebrow">Built in Ethiopia &middot; Made for every neighbourhood</span>
      <h1>Your neighbourhood, <span class="g">within reach.</span></h1>
      <p class="sub">ZAYA connects nearby shops and their customers in one trusted local-commerce network &mdash; so every search and sale starts closer to home.</p>
      <div class="who">
        <a class="chip" href="#experience" data-role-jump="merchant">For <b>merchants</b></a>
        <a class="chip" href="#experience" data-role-jump="customer">For <b>customers</b></a>
        <a class="chip" href="#experience" data-role-jump="diaspora">For the <b>diaspora</b></a>
      </div>
      <div class="hcta">
        <a class="btn btn-primary" href="#contact"><span>Join the pilot</span><svg class="ar" viewBox="0 0 24 24"><path d="M5 12h14M13 6l6 6-6 6"/></svg></a>
        <a class="btn btn-ghost" href="#experience">See how it works</a>
      </div>
    </div>
    <div class="hero-visual" role="img" aria-label="The ZAYA network: a central hub linked to six parts — customers, merchants and nearby shops, plus browsing nearby, comparing prices and the credit book.">
      <div class="hubwrap">
        <canvas id="eco" aria-hidden="true"></canvas>
        <div class="hub-core" aria-hidden="true">
          <svg class="hub-mark" viewBox="0 0 512 512" role="img" aria-hidden="true">
            <path d="M333.7 249.2 L256 372 L178.3 249.2 A92 92 0 1 1 333.7 249.2 Z" fill="#fff"/>
            <circle cx="256" cy="200" r="52" fill="#FF7A45"/>
            <polyline points="226,182 284,182 228,218 286,218" fill="none" stroke="#fff" stroke-width="17" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span class="hub-word">ZAYA</span>
        </div>
        {HUB.map((n) => (
          <span class={`hub-node hub-${n.tone}`} data-key={n.key} style={`left:${n.xp}%;top:${n.yp}%`}>
            <span class="hub-badge">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={n.d}/></svg>
            </span>
            <span class="hub-name">{n.label}</span>
          </span>
        ))}
      </div>
    </div>
  </div>
</div>

<div class="trust-rail" aria-label="ZAYA at a glance">
  <div class="wrap trust-rail-in">
    <div><span>Pilot focus</span><b>Addis Ababa</b></div>
    <div><span>Merchant tools</span><b>Live now</b></div>
    <div><span>Customer app</span><b>Launching</b></div>
    <div><span>One promise</span><b>Honest progress</b></div>
  </div>
</div>

<section class="band"><div class="wrap">
  <div class="sec-head">
    <span class="eyebrow" id="problems">The problem today</span>
    <h2>Everyday commerce runs on memory, paper, and guesswork.</h2>
  </div>
  <div class="pain-grid">
    <div class="pain">
      <h3><span class="d"></span>Customers</h3>
      <ul>
        <li>Hard to find the right shops nearby.</li>
        <li>No way to know prices before you go.</li>
        <li>Long trips across Addis for small errands.</li>
        <li>Delivery is slow, informal, or unavailable.</li>
      </ul>
    </div>
    <div class="pain">
      <h3><span class="d"></span>Merchants</h3>
      <ul>
        <li>Stock counted by hand and by memory.</li>
        <li>Credit tracked on paper that gets lost.</li>
        <li>Little visibility into what actually sells.</li>
        <li>No presence online for new customers to find.</li>
      </ul>
    </div>
    <div class="pain">
      <h3><span class="d"></span>Diaspora</h3>
      <ul>
        <li>Hard to support family from far away.</li>
        <li>Money sent home, hoping it becomes what's needed.</li>
        <li>No visibility into whether goods arrived.</li>
        <li>No simple way to buy the exact items back home.</li>
      </ul>
    </div>
  </div>
</div></section>

<section class="solve">
  <div class="wrap">
    <div class="sec-head">
      <span class="eyebrow" id="solutions">How ZAYA helps</span>
      <h2>One platform that removes the everyday friction of local commerce.</h2>
      <p>Real tools for real problems — honestly labelled by what's live today and what's on the way.</p>
    </div>
    <div class="cards">
      <div class="card"><div class="ic"><svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4-4"/></svg></div><h3>Find shops nearby <span class="st launch">Launching</span></h3><p>Search the shops and services around you and see who has what, close to home.</p></div>
      <div class="card"><div class="ic"><svg viewBox="0 0 24 24"><path d="M6 3v18M18 3v18M6 8h12M6 14h12"/></svg></div><h3>Compare fair prices <span class="st launch">Launching</span></h3><p>Check prices across nearby shops before you spend a single Birr.</p></div>
      <div class="card"><div class="ic"><svg viewBox="0 0 24 24"><path d="M4 7h16M4 12h16M4 17h10"/></svg></div><h3>Manage inventory <span class="st live">Live</span></h3><p>Track stock in one phone and get told before you run out.</p></div>
      <div class="card co"><div class="ic"><svg viewBox="0 0 24 24"><path d="M4 6h16v12H4zM4 10h16"/></svg></div><h3>Digital credit ledger <span class="st live">Live</span></h3><p>Every debt written down and kept honest — never half-remembered.</p></div>
      <div class="card"><div class="ic"><svg viewBox="0 0 24 24"><path d="M12 3a9 9 0 100 18 9 9 0 000-18zM9 12l2 2 4-4"/></svg></div><h3>Smart search <span class="st road">Roadmap</span></h3><p>Ask in plain words and let ZAYA find the right shop and item.</p></div>
      <div class="card"><div class="ic"><svg viewBox="0 0 24 24"><path d="M12 3v11M9 6l3-3 3 3M6 14v5h12v-5"/></svg></div><h3>Voice support <span class="st road">Roadmap</span></h3><p>Run your shop by voice, in Amharic, Afaan Oromoo, Tigrinya or English.</p></div>
      <div class="card"><div class="ic"><svg viewBox="0 0 24 24"><path d="M5 4h11l3 3v13H5zM9 9h6M9 13h6"/></svg></div><h3>OCR invoice scanning <span class="st road">Roadmap</span></h3><p>Snap a supplier invoice and let ZAYA add the stock for you.</p></div>
      <div class="card co"><div class="ic"><svg viewBox="0 0 24 24"><circle cx="7" cy="18" r="2"/><circle cx="17" cy="18" r="2"/><path d="M3 5h3l2 10h9l2-7H7"/></svg></div><h3>Local delivery <span class="st road">Roadmap</span></h3><p>Orders fulfilled by the shop and delivered by someone local.</p></div>
      <div class="card co"><div class="ic"><svg viewBox="0 0 24 24"><path d="M12 21s-7-5.5-7-11a7 7 0 0114 0c0 5.5-7 11-7 11z"/><circle cx="12" cy="10" r="2.5"/></svg></div><h3>Provide for family <span class="st road">Roadmap</span></h3><p>Order real goods to a trusted neighbourhood shop — delivered, with proof.</p></div>
    </div>
  </div>
</section>

<section class="role-section" id="experience">
  <div class="wrap">
    <div class="role-heading">
      <div><span class="eyebrow">Choose your ZAYA</span><h2>One platform. A different win for everyone.</h2></div>
      <p>Pick your role to see how ZAYA fits into your day &mdash; and what is live now versus coming next.</p>
    </div>
    <div class="role-explorer" data-role-explorer>
      <div class="role-tabs" role="tablist" aria-label="Choose how you use ZAYA">
        <button type="button" role="tab" id="role-tab-merchant" aria-controls="role-pane-merchant" aria-selected="true" data-role="merchant"><span>01</span>Merchant</button>
        <button type="button" role="tab" id="role-tab-customer" aria-controls="role-pane-customer" aria-selected="false" data-role="customer" tabindex="-1"><span>02</span>Customer</button>
        <button type="button" role="tab" id="role-tab-diaspora" aria-controls="role-pane-diaspora" aria-selected="false" data-role="diaspora" tabindex="-1"><span>03</span>Diaspora</button>
      </div>

      <article class="role-pane is-active" role="tabpanel" id="role-pane-merchant" aria-labelledby="role-tab-merchant" data-role-pane="merchant">
        <div class="role-media"><img loading="lazy" src={creditBook.src} alt="A shop owner managing the digital credit book with ZAYA" /><span class="role-status live">Live &middot; pilot</span></div>
        <div class="role-copy"><span class="role-kicker">Run the whole shop from one phone</span><h3>Sell faster. Know your stock. Keep every credit clear.</h3><p>ZAYA gives neighbourhood merchants the everyday tools that matter first&mdash;sales, inventory, credit and a clear view of the day.</p><ul><li>Fast point-of-sale flow</li><li>Live stock tracking</li><li>Digital customer credit book</li></ul><div class="role-actions"><a class="btn btn-primary" href="#contact">Join as a merchant</a></div></div>
      </article>

      <article class="role-pane" role="tabpanel" id="role-pane-customer" aria-labelledby="role-tab-customer" data-role-pane="customer" hidden>
        <div class="role-media"><img loading="lazy" src={customerApp.src} alt="A customer comparing local choices with ZAYA" /><span class="role-status launch">Launching</span></div>
        <div class="role-copy"><span class="role-kicker">Find what you need closer to home</span><h3>Nearby shops, clearer choices and fewer wasted trips.</h3><p>The customer experience is being prepared to help people discover real local stock and compare prices before leaving home.</p><ul><li>Nearby shop discovery</li><li>Price comparison in Birr</li><li>Simple local ordering</li></ul><div class="role-actions"><a class="btn btn-primary" href="#contact">Get launch updates</a></div></div>
      </article>

      <article class="role-pane" role="tabpanel" id="role-pane-diaspora" aria-labelledby="role-tab-diaspora" data-role-pane="diaspora" hidden>
        <div class="role-media"><img loading="lazy" src={diasporaFamily.src} alt="A family receiving essential goods at home" /><span class="role-status road">Our vision</span></div>
        <div class="role-copy"><span class="role-kicker">Our vision for the diaspora</span><h3>Choose the basket. Trust the local shop. See proof it arrived.</h3><p>Where we want to take ZAYA next: choose real goods&mdash;not send money&mdash;through a trusted neighbourhood shop, delivered with proof. On the roadmap, not live yet.</p><ul><li>Choose essential goods</li><li>One clear shelf-price flow</li><li>Local delivery with proof</li></ul><div class="role-actions"><a class="btn btn-primary" href="#contact">Follow the roadmap</a></div></div>
      </article>
    </div>
  </div>
</section>

<section class="showcase">
  <div class="wrap">
    <div class="sec-head"><span class="eyebrow">In real Ethiopian shops</span><h2>Built with the shops that run the neighbourhood.</h2><p>From the corner mini-market to the supermarket — this is where ZAYA works.</p></div>
    <div class="mosaic">
      <div class="shot reveal"><span class="tagpin">Live · pilot</span><img loading="lazy" src={storefront.src} alt="A ZAYA-powered neighbourhood mini market at dusk"><div class="cap">A modern mini market<span>Stocked, lit, and online</span></div></div>
      <div class="shot reveal"><span class="tagpin">A sale in ~5s</span><img loading="lazy" src={counterSale.src} alt="A shop owner serving a customer at the counter"><div class="cap">Serve, ring up, done<span>The whole counter, in one phone</span></div></div>
      <div class="shot reveal"><img loading="lazy" src={supermarket.src} alt="A modern Ethiopian supermarket aisle"><div class="cap">Shop to supermarket<span>One platform, any size</span></div></div>
      <div class="shot reveal"><img loading="lazy" src={stockCheck.src} alt="A shop owner checking stock on the shelves with a phone"><div class="cap">Stock, always in hand<span>Know before you run out</span></div></div>
    </div>
  </div>
</section>



<section class="band" id="diaspora">
  <div class="wrap">
    <div class="sec-head"><span class="eyebrow">Our vision — for the diaspora</span>
      <h2>Provide for your family — real goods, not cash into the dark.</h2>
      <p>A trusted neighbourhood shop, delivered locally, with proof it arrived. <b style="color:#5648B0">On the roadmap.</b> ZAYA is not a money-transfer service.</p></div>
    <div class="flow reveal-seq">
      <div class="fstep"><div class="fn"><span class="num">1</span><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="9"/><path d="M3 12h18M12 3c3 3 3 15 0 18M12 3c-3 3-3 15 0 18"/></svg></div><h3>You order from abroad</h3><p>Choose your family's trusted neighbourhood shop.</p></div>
      <div class="farr"><svg viewBox="0 0 24 24"><path d="M5 12h14M13 6l6 6-6 6"/></svg></div>
      <div class="fstep"><div class="fn"><span class="num">2</span><svg viewBox="0 0 24 24"><circle cx="9" cy="20" r="1.6"/><circle cx="18" cy="20" r="1.6"/><path d="M3 4h3l2.4 12h9.6l2-8H7"/></svg></div><h3>Order through ZAYA</h3><p>Shelf prices + one clear fee — no gift-shop markup.</p></div>
      <div class="farr"><svg viewBox="0 0 24 24"><path d="M5 12h14M13 6l6 6-6 6"/></svg></div>
      <div class="fstep"><div class="fn"><span class="num">3</span><svg viewBox="0 0 24 24"><path d="M4 9l1-4h14l1 4M4 9v10h16V9M4 9h16M9 19v-5h6v5"/></svg></div><h3>The shop prepares it</h3><p>The neighbourhood merchant fulfils the order.</p></div>
      <div class="farr"><svg viewBox="0 0 24 24"><path d="M5 12h14M13 6l6 6-6 6"/></svg></div>
      <div class="fstep"><div class="fn"><span class="num">4</span><svg viewBox="0 0 24 24"><circle cx="6" cy="18" r="3"/><circle cx="18" cy="18" r="3"/><path d="M9 18h6M6 18l4-9h4l2 4"/></svg></div><h3>Delivered locally</h3><p>The neighbourhood shop arranges local delivery.</p></div>
      <div class="farr"><svg viewBox="0 0 24 24"><path d="M5 12h14M13 6l6 6-6 6"/></svg></div>
      <div class="fstep"><div class="fn"><span class="num">5</span><svg viewBox="0 0 24 24"><path d="M4 5h16v12H4z"/><path d="M8 21h8M9 11l2 2 4-4"/></svg></div><h3>Family receives — with proof</h3><p>You get a delivery photo. Optional monthly basket.</p></div>
    </div>
  </div>
</section>

<section class="band"><div class="wrap">
  <div class="sec-head"><span class="eyebrow" id="faq">Questions</span><h2>Straight answers.</h2></div>
  <div class="faq">
    {faq.items.map((item) => (
      <details class="acc"><summary>{item.q}<span class="pl"></span></summary><div class="acc-b">{item.a}</div></details>
    ))}
  </div>
</div></section>


<section class="ask-band">
  <div class="wrap ask-band-in reveal-seq">
    <div class="ask-orb" aria-hidden="true">&#10022;</div>
    <div><span class="eyebrow">Need a quick answer?</span><h2>Ask ZAYA before you scroll another step.</h2><p>Get a grounded answer about the pilot, merchant plans, product status or the roadmap.</p></div>
    <button class="btn btn-primary" type="button" data-open-assistant>Start a conversation <span aria-hidden="true">&rarr;</span></button>
  </div>
</section>


<section class="band">
  <div class="wrap">
    <div class="sec-head"><span class="eyebrow" id="pricing">Pricing</span><h2>Simple plans. No hidden fees.</h2><p>Customers use ZAYA free. Merchants start free — forever — and upgrade only when it helps.</p></div>
    <div class="priceg">
      {pricing.tiers.map((t) => (
        <div class={t.highlight ? 'pcard pfeat' : 'pcard'}>
          {t.highlight && <span class="ptag">Most popular</span>}
          <div class="pn">{t.name}</div>
          <div class="pp">{t.from ? 'from ' : ''}{t.price} {pricing.currency} <small>/ {t.from ? 'mo + branch' : (t.period === 'forever' ? 'forever' : 'month')}</small></div>
          <div class="pd">{t.blurb}</div>
          <ul>{t.features.map((f) => (<li>{f}</li>))}</ul>
          <a class={t.highlight ? 'btn btn-primary' : 'btn btn-ghost'} href="#contact">{t.cta}</a>
        </div>
      ))}
    </div>
    <p class="price-note">{pricing.note}</p>
  </div>
</section>
<section class="band" id="contact">
  <div class="wrap">
    <div class="sec-head"><span class="eyebrow">Contact us</span><h2>Let's grow your shop together.</h2><p>Call, message, email, or visit — we answer every message ourselves.</p></div>
    <div class="contact-cards">
      <a class="ccard" href={telHref(contact.phones[0])}><div class="ci"><svg viewBox="0 0 24 24"><path d="M5 4h4l2 5-3 2a12 12 0 0 0 5 5l2-3 5 2v4a2 2 0 0 1-2 2A16 16 0 0 1 3 6a2 2 0 0 1 2-2"/></svg></div><div class="ck">Call us</div><div class="cv">{contact.phones[0]}</div></a>
      <a class="ccard co" href={`https://wa.me/${contact.whatsapp}`} target="_blank" rel="noopener"><div class="ci"><svg viewBox="0 0 24 24"><path d="M12 3a9 9 0 0 0-7.7 13.7L3 21l4.4-1.2A9 9 0 1 0 12 3z"/><path d="M8.5 8.5c0 4 3 7 7 7"/></svg></div><div class="ck">WhatsApp</div><div class="cv">Chat with us</div></a>
      <a class="ccard" href={`mailto:${contact.email}`}><div class="ci"><svg viewBox="0 0 24 24"><path d="M4 6h16v12H4z"/><path d="M4 7l8 6 8-6"/></svg></div><div class="ck">Email</div><div class="cv">{contact.email}</div></a>
      <a class="ccard co" href={`https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(contact.mapsQuery)}`} target="_blank" rel="noopener"><div class="ci"><svg viewBox="0 0 24 24"><path d="M12 21s-7-5.5-7-11a7 7 0 0 1 14 0c0 5.5-7 11-7 11z"/><circle cx="12" cy="10" r="2.5"/></svg></div><div class="ck">Visit</div><div class="cv">{contact.location}</div></a>
    </div>
    <form class="pilot-form" name="pilot" method="POST" data-netlify="true" netlify-honeypot="bot-field" action="/?joined=1#contact">
      <input type="hidden" name="form-name" value="pilot" />
      <p class="pf-hp"><label>Leave this field empty <input name="bot-field" /></label></p>
      <div class="pf-head">Join the pilot</div>
      <div class="pf-row">
        <label>Your name<input name="name" type="text" required autocomplete="name" /></label>
        <label>Phone<input name="phone" type="tel" required autocomplete="tel" placeholder="+251 …" /></label>
      </div>
      <label>Shop name <span class="pf-opt">(optional)</span><input name="shop" type="text" /></label>
      <label>Message<textarea name="message" rows="3" placeholder="Tell us a little about your shop"></textarea></label>
      <button class="btn btn-primary" type="submit">Join the pilot</button>
      <p class="pf-note">{contact.formPrivacyNote}</p>
      <p class="pf-success" id="pfok">✓ Thank you — we&rsquo;ll be in touch about the pilot soon.</p>
    </form>
  </div>
</section>

