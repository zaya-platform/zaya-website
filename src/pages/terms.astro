---
import Base from '../layouts/Base.astro';
import { getEntry } from 'astro:content';
const entry = await getEntry('legal', 'terms');
const { Content } = await entry.render();
---
<Base title="Terms of Use — ZAYA App" description="The terms that govern use of the ZAYA public website.">
  <div class="legal-page">
    <div class="wrap">
      <a class="legal-back" href="/">&larr; Back to ZAYA</a>
      <article class="legal-prose"><Content /></article>
    </div>
  </div>
</Base>
