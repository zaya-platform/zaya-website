---
import '../styles/typography.css';
import '../styles/tokens.css';
import '../styles/site.css';
import site from '../content/data/site.json';
import AssistantWidget from '../components/AssistantWidget.astro';

interface Props { title?: string; description?: string; }
const {
  title = `${site.brandName} — ${site.tagline}`,
  description = "Ethiopia's local commerce, connected in one intelligent app — for customers, merchants and diaspora families.",
} = Astro.props;

// F4 BINDING honesty gate: until real Privacy/Terms exist and site.published is
// flipped true, the whole site stays noindex. robots.txt + scripts/check-publish.mjs
// enforce the same rule at build time.
const noindex = !site.published;
// Config-driven canonical (Astro.site = $URL on Netlify, else zayaethiopia.com).
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const socialImage = new URL('/og.png', Astro.site).href;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#1E2A4A" />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="ZAYA App" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={socialImage} />
    <meta property="og:image:alt" content="ZAYA App — Your neighbourhood, within reach." />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    {/* Enable JS-gated entrance/scroll animations. If JS is off or the bundle
        fails, this never runs and the full static page renders (no hidden copy).
        Runs before first paint, so there is no flash of un-animated content. */}
    <script is:inline>document.documentElement.classList.add('js')</script>
  </head>
  <body>
    <slot />
    {/* Website AI Assistant — founder-access preview (CR-027/ADR-024, FDR-019 W-D4a).
        Ships while published:false; the public launch is the W-D4b gate. */}
    <AssistantWidget />
    <script>
      import '../scripts/site.js';
    </script>
  </body>
</html>
