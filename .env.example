# ZAYA website — environment placeholders. NEVER commit real values.
# Real secrets live ONLY in Netlify → Site settings → Environment variables.

# Website AI Assistant (CR-027/ADR-024). Generate a free key at
# https://aistudio.google.com → "Get API key", then set it in Netlify env —
# see docs/ASSISTANT-SETUP.md. The assistant's curated answers work WITHOUT
# this key; only the English AI-fallback needs it.
GEMINI_API_KEY=

# Optional: override the model (defaults to gemini-2.5-flash).
# GEMINI_MODEL=gemini-2.5-flash

# CMS OAuth relay (already configured in Netlify env; listed here for completeness).
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
